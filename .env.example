# Example environment variables (do not store secrets here)
# Primary DB connection (optional full DSN)
DATABASE_URL=

# PostgreSQL connection details (used by load_demo_pg.py and local testing)
# You can either set these individually or provide a full DATABASE_URL DSN.
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=secret
PGDATABASE=jobmanager

# Example full DSN (uncomment to use):
# DATABASE_URL=postgresql://postgres:secret@localhost:5432/jobmanager

# Note: enable pgcrypto extension in the DB for `gen_random_uuid()`:
# psql -U postgres -d jobmanager -c "CREATE EXTENSION IF NOT EXISTS pgcrypto;"

REDIS_URL=
JOB_WORKER_CONCURRENCY=4
